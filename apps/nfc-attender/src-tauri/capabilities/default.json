{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:allow-version",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "process:allow-restart",
    "updater:default"
  ]
}
